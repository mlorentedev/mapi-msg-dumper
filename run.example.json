{
  "provider": {
    "type": "outlook",
    "config": {}
  },
  "extraction": {
    "start_date": "2025-01-01",
    "end_date": "2025-01-31",
    "cadence": "monthly",
    "manual": true,
    "max_windows": 1,
    "dry_run": true
  },
  "outputs": {
    "raw_root": "./exports/raw",
    "markdown_root": "./exports/markdown",
    "save_raw": true
  },
  "folders": [
    {
      "path": "Inbox",
      "tags": ["personal"]
    },
    {
      "path": "Shared Inbox\\Support",
      "tags": ["work", "support"],
      "children": [
        "Archives/2024"
      ]
    }
  ],
  "verbose": true
}
